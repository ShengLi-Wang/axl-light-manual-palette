{
  "name": "axl-light",
  "version": "0.1.0",
  "private": true,
  "description": "Non-invasive Obsidian reading annotations for Markdown and PDF with overlay highlights, sticky notes, and sidecar storage.",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "version": "node -e \"const fs=require('fs');const manifest=require('./manifest.json');const versions=require('./versions.json');versions[manifest.minAppVersion]=manifest.version;fs.writeFileSync('./versions.json', JSON.stringify(versions, null, 2)+'\\n');\""
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^20.14.10",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.7.2",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3"
  }
}
